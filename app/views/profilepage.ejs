<%- include('partials/header', {title: 'GroCrop', cssFiles: ['profilepage.css'], topNavBar: false}) %>
  <div class="content">
    <h1>Your Profile</h1>

  </br>
    <% if (typeof message !== 'undefined') { %>
      <p id="message" style="color: green;"><%= message %></p>
    <% } %>
    <% if (typeof errorMessage !== 'undefined') { %>
      <p id="message" style="color: red;"><%= errorMessage %></p>
    <% } %>

    <div class="field">
      <label for="inp-username">Username</label>
      <div class="value" id="val-username"><%= user.username %></div>
      <input type="text" id="inp-username" name="username" value="<%= user.username %>" autocomplete="username"/>
    </div>

    <div class="field">
      <label for="inp-email">Email</label>
      <div class="value" id="val-email"><%= user.email %></div>
      <input type="email" id="inp-email" name="email" value="<%= user.email %>" autocomplete="email"/>
    </div>

    <div class="field">
      <label>Password</label>
      <div class="value" id="val-password">•••••••••</div>
      <input type="password" id="inp-password" name="password" placeholder="New password" autocomplete="new-password"/>
      <input type="password" id="inp-password-confirm" name="passwordConfirm" placeholder="Confirm new password" autocomplete="new-password"/>
    </div>
    <p id="client-error" style="color: red; display:none;"></p>

    <div class="field">
      <label>Location</label>
      <% if (user.zone) { %>
      Current Zone: <%= user.zone %>
      <% } %>
      <div class="value" id="val-location">
        <%= user.city ? user.city.charAt(0).toUpperCase() + user.city.slice(1) : 'Not set' %>
      </div>

      <div id="inp-location" style="display:none;">
        <div class="dropdown">
          <button type="button" onclick="toggleDropdown()" class="dropbtn" id="location-dropbtn">
            <%= user.city ? user.city.charAt(0).toUpperCase() + user.city.slice(1) : 'Select City' %> ▼
          </button> 
          <div id="cityDropdown" class="dropdown-content" style="display:none;">
            <input type="text" placeholder="Search" id="citySearch" onkeyup="filterCities()" />
            <% cities.forEach(c => { %>
              <a href="#" data-city="<%= c.name.toLowerCase() %>" data-zone="<%= c.zoneName %>" onclick="selectCity(this, event)">
                <%= c.name %>
              </a>
            <% }) %>
          </div>
        </div>

        <p id="selectedDisplay" <% if (!user.zone) { %> style="display:none;" <% } %>>
          Zone: <strong id="displayZone"><%= user.zone || '' %></strong>
        </p>
      </div>
    </div>

    <!-- Pre-filled with existing city so it submits even if user doesn't change it -->
    <input type="hidden" id="cityInput" value="<% if (user.city) { %><%= user.city %><% } %>" />

  </br>
    <button id="edit-btn" onclick="startEdit()">Edit profile</button>
    <button id="save-buttn" onclick="submitProfile()">Save changes</button>
    <button id="cancel-btn" onclick="cancelEdit()">Cancel</button>

    <form id="profile-form" action="/updateProfile" method="POST" style="display:none">
      <input type="hidden" id="form-username" name="username" />
      <input type="hidden" id="form-email" name="email" />
      <input type="hidden" id="form-city" name="city" />
      <input type="hidden" id="form-password" name="password" />
    </form>

    </br>
    </br>
    
    <button id="logout-btn" onclick="showLogoutPrompt()" autocomplete="off">Log out</button>

    <div id="logout-prompt">
        <div class="prompt-box">
            <h2>Log out?</h2>
            <p>You'll need to log back in to access your account.</p>
            <div class="prompt-actions">
                <button class="prompt-cancel" onclick="hideLogoutPrompt()">Cancel</button>
                <button class="prompt-confirm" onclick="confirmLogout()">Log out</button>
            </div>
        </div>
    </div>

  </div>
<%- include('partials/footer', { jsFiles: ['profile.js'], botNavBar: true, activePage: null }) %>
